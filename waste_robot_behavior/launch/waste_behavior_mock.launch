<launch>
  <arg name="model_path" default="yolov8n.pt"/>
  <arg name="image_topic" default="/camera/image"/>
  <arg name="depth_topic" default="/camera/depth/image_raw"/>
  <arg name="camera_info_topic" default="/camera/camera_info"/>

  <node pkg="waste_robot_behavior" type="yolo_rgbd_detector_node.py" name="yolo_rgbd_detector_node" output="screen">
    <param name="model_path" value="$(arg model_path)"/>
    <param name="image_topic" value="$(arg image_topic)"/>
    <param name="depth_topic" value="$(arg depth_topic)"/>
    <param name="camera_info_topic" value="$(arg camera_info_topic)"/>
    <param name="confidence_threshold" value="0.45"/>
  </node>

  <node pkg="waste_robot_behavior" type="waste_behavior_node.py" name="waste_behavior_node" output="screen">
    <param name="detections_topic" value="/yolo_rgbd_detector_node/detections"/>
    <param name="feedback_topic" value="/waste_behavior_node/feedback"/>
    <param name="approach_distance_m" value="0.6"/>
    <param name="person_safety_distance_m" value="1.2"/>
  </node>

  <node pkg="waste_robot_behavior" type="mock_robot_io_node.py" name="mock_robot_io_node" output="screen">
    <param name="decision_topic" value="/waste_behavior_node/decision"/>
    <param name="feedback_topic" value="/waste_behavior_node/feedback"/>
  </node>
</launch>
