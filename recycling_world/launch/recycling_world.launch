<!-- 
  LAUNCH: recycling_world.launch
  Inicia el món de reciclatge amb TurtleBot3 en Gazebo
  
  ÚS:
    export TURTLEBOT3_MODEL=burger
    roslaunch recycling_world recycling_world.launch
-->
<launch>
  <!-- Model TurtleBot3 (burger / waffle / waffle_pi) -->
  <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="Model del TurtleBot3"/>
  <!-- Posició inicial del robot (davant de l'entrada, centre de l'entorn) -->
  <arg name="x_pos" default="-0.5"/>
  <arg name="y_pos" default="-4.0"/>
  <arg name="z_pos" default="0.0"/>

  <!-- Carregar el món de reciclatge -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find recycling_world)/worlds/recycling_world.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <!-- Carregar descripció URDF del TurtleBot3 -->
  <param name="robot_description"
    command="$(find xacro)/xacro --inorder
      $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro"/>

  <!-- Publicar l'estat del robot (TF entre links) -->
  <node pkg="robot_state_publisher" type="robot_state_publisher"
        name="robot_state_publisher">
    <param name="publish_frequency" type="double" value="50.0"/>
  </node>

  <!-- Spawn del robot TurtleBot3 a Gazebo -->
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf"
        args="-urdf -model turtlebot3_$(arg model)
              -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos)
              -param robot_description"/>
</launch>
