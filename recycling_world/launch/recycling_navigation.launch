<!--
  LAUNCH: recycling_navigation.launch
  Inicia la localització AMCL + map_server per a l'entorn de reciclatge
  (Un cop ja teniu el mapa creat amb recycling_slam.launch)

  ÚS:
    T1: roscore
    T2: roslaunch recycling_world recycling_world.launch
    T3: roslaunch recycling_world recycling_navigation.launch map_file:=/path/al/recycling_map.yaml
    T4: rosrun rviz rviz -d $(find recycling_world)/rviz/navigation.rviz
    
  Per establir la posició inicial del robot a RViz:
    - Useu l'eina "2D Pose Estimate"
-->
<launch>
  <!-- Fitxer de mapa (creat prèviament amb map_saver) -->
  <arg name="map_file"
       default="$(find recycling_world)/maps/recycling_map.yaml"/>

  <!-- ====== NODE MAP_SERVER ====== -->
  <!-- Proporciona les dades del mapa al node amcl i a la navegació -->
  <node pkg="map_server" type="map_server" name="map_server"
        args="$(arg map_file)" output="screen"/>

  <!-- ====== NODE AMCL (localització Monte Carlo Adaptativa) ====== -->
  <node pkg="amcl" type="amcl" name="amcl" output="screen">

    <!-- Posició inicial del robot (centre-baix de l'entorn) -->
    <param name="initial_pose_x" value="-0.5"/>
    <param name="initial_pose_y" value="-4.0"/>
    <param name="initial_pose_a" value="0.0"/>

    <!-- Eixos de referència -->
    <param name="global_frame_id"   value="map"/>
    <param name="odom_frame_id"     value="odom"/>
    <param name="base_frame_id"     value="base_footprint"/>

    <!-- Model d'odometria diferencial (TurtleBot3) -->
    <param name="odom_model_type" value="diff"/>
    <param name="odom_alpha1"     value="0.1"/>
    <param name="odom_alpha2"     value="0.1"/>
    <param name="odom_alpha3"     value="0.1"/>
    <param name="odom_alpha4"     value="0.1"/>
    <param name="odom_alpha5"     value="0.1"/>

    <!-- Paràmetres del filtre de partícules -->
    <param name="min_particles"         value="500"/>
    <param name="max_particles"         value="3000"/>
    <param name="kld_err"               value="0.05"/>
    <param name="kld_z"                 value="0.99"/>
    <param name="update_min_d"          value="0.1"/>
    <param name="update_min_a"          value="0.2"/>
    <param name="resample_interval"     value="1"/>
    <param name="transform_tolerance"   value="0.5"/>
    <param name="recovery_alpha_slow"   value="0.000"/>
    <param name="recovery_alpha_fast"   value="0.000"/>

    <!-- Paràmetres del làser -->
    <param name="laser_model_type"      value="likelihood_field"/>
    <param name="laser_min_range"       value="0.1"/>
    <param name="laser_max_range"       value="3.5"/>
    <param name="laser_max_beams"       value="60"/>
    <param name="laser_z_hit"           value="0.5"/>
    <param name="laser_z_short"         value="0.05"/>
    <param name="laser_z_max"           value="0.05"/>
    <param name="laser_z_rand"          value="0.5"/>
    <param name="laser_sigma_hit"       value="0.2"/>
    <param name="laser_lambda_short"    value="0.1"/>
    <param name="laser_likelihood_max_dist" value="2.0"/>

    <!-- Obtenir el mapa via topic (no servei) -->
    <param name="use_map_topic"   value="true"/>
    <param name="first_map_only"  value="true"/>

    <!-- Taxa de publicació de la posició estimada per a visualització -->
    <param name="gui_publish_rate" value="10.0"/>
  </node>
</launch>
